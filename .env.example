# Optional. Needed only when you enable "Claude verify top leads".
ANTHROPIC_API_KEY=sk-ant-api03-your-key

# Keep this cheap for testing. Override if Anthropic changes model availability.
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Optional. Local SQLite database used for memory, growth history and enrichment cache.
# Defaults to data/novapolis.sqlite.
NOVAPOLIS_DB_PATH=data/novapolis.sqlite
